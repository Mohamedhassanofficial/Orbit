# Root env for docker-compose (copy to .env; compose reads it automatically).

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Blockchain (BNB Smart Chain)
BSC_RPC_URL=https://bsc-dataseed.binance.org
CHAIN_ID=56

# Deployed contract addresses (fill after `cd contracts && npm run deploy:testnet`)
TOKEN_ADDRESS=
STAKING_ADDRESS=
REFERRAL_ADDRESS=
PRESALE_ADDRESS=

# Frontend origin(s) allowed by CORS
CORS_ORIGINS=http://localhost:5173

# Indexer
INDEXER_POLL_SECONDS=10

# Referral payout automation — backend distributor that pushes rewards after 30h.
# Must be the Referral contract's distributor and funded with BNB for gas.
DISTRIBUTOR_PRIVATE_KEY=
REFERRAL_DELAY_HOURS=30
REFERRAL_MAX_HOURS=72
REFERRAL_REWARD_BPS=1000
DISTRIBUTOR_ADDRESS=
