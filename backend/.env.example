# --- Database (MySQL) ---
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql+pymysql://orbit:orbit@localhost:3306/orbit

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# --- Blockchain (BNB Smart Chain) ---
BSC_RPC_URL=https://bsc-dataseed.binance.org
CHAIN_ID=56

# Deployed contract addresses (fill after `npm run deploy`)
TOKEN_ADDRESS=
STAKING_ADDRESS=
REFERRAL_ADDRESS=
PRESALE_ADDRESS=

# Block to start indexing from (0 = latest on first run)
INDEXER_START_BLOCK=0
INDEXER_POLL_SECONDS=10

# --- Referral reward automation ---
# Private key of the backend distributor that PUSHES referral payouts. It must be
# set as the Referral contract's distributor (deploy.js) and funded with BNB for
# gas; the Referral contract must hold $ORB (fund()). NEVER commit a real key.
DISTRIBUTOR_PRIVATE_KEY=
REFERRAL_DELAY_HOURS=30
REFERRAL_MAX_HOURS=72
REFERRAL_REWARD_BPS=1000

# CORS — your frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:5173
